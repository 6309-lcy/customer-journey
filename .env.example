# ============================================================
# Client Profile Management System - Environment Variables
# Copy this file to .env and fill in real values (never commit .env)
# ============================================================

# MySQL Connection (local or remote)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=client_profile_db

# Simple password login for Streamlit session_state protection
# Change to a strong password. Falls back to "demo123" if empty.
DASHBOARD_PASSWORD=ChangeMeStrong123!

# ============================================================
# Frontend testing mode (highly recommended for UI development/testing)
# ============================================================
# When set to true, the app uses in-memory sample data instead of MySQL.
# All operations work, but data resets on page refresh or app restart.
# Perfect for quick frontend testing without a database.
USE_SAMPLE_DATA=true
