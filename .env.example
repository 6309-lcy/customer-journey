# # ============================================================
# # Client Profile Management System - Environment Variables
# # Copy this file to .env and fill in real values (never commit .env)
# # ============================================================

# # MySQL Connection (local or remote) -- configure for your MySQL database
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DATABASE=cj

# # Simple password login for Streamlit session_state protection
# # Change to a strong password. Falls back to "demo123" if empty.
# DASHBOARD_PASSWORD=ChangeMeStrong123!

# # ============================================================
# # Frontend testing mode (highly recommended for UI development/testing)
# # ============================================================
# # When set to true, the app uses in-memory sample data instead of MySQL.
# # All operations work, but data resets on page refresh or app restart.
# # Perfect for quick frontend testing without a database.
# #
# # TO JUST CONNECT TO A NEW MYSQL DATABASE (real persistence):
# #   1. Set USE_SAMPLE_DATA=false below
# #   2. Fill the MYSQL_* values above (point to your new DB)
# #   3. Run sql/init_mysql_schema.sql in your MySQL tool (creates tables + web_store_url column + 3 samples)
# #   4. streamlit run main.py   (or restart any running instance)
# #
# # The profile page, add logs/sales/deliveries, maps, totals, CSV etc all write to the real DB.
# USE_SAMPLE_DATA=false
